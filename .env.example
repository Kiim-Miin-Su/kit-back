# ──────────────────────────────────────────────
# 서버 설정
# ──────────────────────────────────────────────
HOST_PORT=4000
PORT=4000
POSTGRES_HOST_PORT=5432
STUDIO_PORT=5555
ADMINER_PORT=8080

# ──────────────────────────────────────────────
# 프론트엔드 (back/docker-compose.yml로 함께 기동)
# docker compose down 시 front도 함께 제거됩니다.
# ──────────────────────────────────────────────
FRONT_HOST_PORT=3000
NEXT_PUBLIC_DEV_ROLE_BYPASS=false
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────────
# 데이터 소스
# memory : DB 없이 인메모리로 즉시 실행 (개발 기본값)
# prisma : PostgreSQL 연결 필요 (docker compose 기본값)
# ──────────────────────────────────────────────
DATA_SOURCE=memory

# ──────────────────────────────────────────────
# PostgreSQL 연결 URL
#   docker compose up 사용 시 → @postgres:5432 (컨테이너 서비스명)
#   로컬 직접 실행 시         → @localhost:${POSTGRES_HOST_PORT}
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres@postgres:5432/ai_edu

# ──────────────────────────────────────────────
# 인증
# AUTH_TOKEN_SECRET : HMAC-SHA256 서명 시크릿
#   - 개발: 미설정 시 코드 내 기본값 사용 (보안 무관)
#   - 프로덕션: 반드시 64자 이상 랜덤 문자열로 설정
#     예) openssl rand -base64 64
# ──────────────────────────────────────────────
AUTH_TOKEN_SECRET=change-me-with-strong-random-secret

# ──────────────────────────────────────────────
# OpenAI
# AI 기능을 사용하지 않으면 그대로 둬도 됩니다.
# ──────────────────────────────────────────────
OPENAI_API_KEY=change-me
