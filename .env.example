PORT=4000
CORS_ORIGIN=http://localhost:3000

# memory | prisma
DATA_SOURCE=memory

# 로컬 직접 실행 시(개발 compose postgres 사용): postgresql://postgres@localhost:5432/ai_edu
# 프로덕션 배포 시: 비밀번호를 포함한 실제 DATABASE_URL로 교체
DATABASE_URL=postgresql://postgres@localhost:5432/ai_edu

# 프로덕션 배포 시 필수
POSTGRES_PASSWORD=your-production-postgres-password
AUTH_TOKEN_SECRET=your-production-auth-token-secret
OPENAI_API_KEY=
