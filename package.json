{
  "name": "ai-edu-back",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "nest start --watch",
    "start:dev:prisma": "DATA_SOURCE=prisma nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "start:prod:prisma": "DATA_SOURCE=prisma node dist/main",
    "start": "node dist/main",
    "setup:env": "node ./scripts/init-env.mjs",
    "setup:env:local": "node ./scripts/init-env.mjs --preset=local-node",
    "test": "npm run build && node --test test/**/*.test.js",
    "test:prisma": "DATA_SOURCE=prisma npm test",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio --browser none --hostname 0.0.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.0.7",
    "@prisma/client": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.1",
    "@nestjs/testing": "^11.0.1",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
